generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id                   String   @id @default(cuid())
  clerkUserId          String   @unique
  businessName         String
  logoUrl              String?
  brandColor           String   @default("#C8F04A")
  businessType         String   @default("other")
  subscriptionStatus   String   @default("trial")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  hideBranding         Boolean  @default(false)
  portalWelcomeMessage String?
  portalPrimaryColor   String?
  supportEmail         String?
  ownerEmail           String?
  createdAt            DateTime @default(now())
  clients              Client[]
  programs             Program[]
  automationRules      AutomationRule[]
  activityEvents       ActivityEvent[]
  notes                Note[]
  automationLogs       AutomationLog[]
}

model Client {
  id                   String    @id @default(cuid())
  workspaceId          String
  workspace            Workspace @relation(fields: [workspaceId], references: [id])
  firstName            String
  lastName             String
  email                String
  phone                String?
  companyName          String?
  assignedTo           String?
  status               String    @default("on_track")
  programId            String?
  program              Program?  @relation(fields: [programId], references: [id])
  inviteToken          String?   @unique
  inviteAccepted       Boolean   @default(false)
  inviteAcceptedAt     DateTime?
  clerkUserId          String?
  invitedAt            DateTime?
  lastActivityAt       DateTime?
  createdAt            DateTime  @default(now())
  tasks                Task[]
  @@unique([workspaceId, email])
  formSubmissions      FormSubmission[]
  agreementAcceptances AgreementAcceptance[]
  milestoneCompletions MilestoneCompletion[]
  checkInSubmissions   CheckInSubmission[]
  activityEvents       ActivityEvent[]
  notes                Note[]
  documentRequests     DocumentRequest[]
  stepCompletions      StepCompletion[]
  automationLogs       AutomationLog[]
}

model Program {
  id               String            @id @default(cuid())
  workspaceId      String
  workspace        Workspace         @relation(fields: [workspaceId], references: [id])
  name             String
  description      String?
  duration         String?
  createdAt        DateTime          @default(now())
  clients          Client[]
  steps            ProgramStep[]
  tasks            Task[]
  agreements       Agreement[]
  milestones       Milestone[]
  checkInTemplates CheckInTemplate[]
}

model ProgramStep {
  id          String  @id @default(cuid())
  programId   String
  program     Program @relation(fields: [programId], references: [id])
  type        String
  title       String
  description String?
  position    Int
  fields      Json?
  completions StepCompletion[]
}

model IntakeForm {
  id          String           @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime         @default(now())
  fields      IntakeFormField[]
  submissions FormSubmission[]
}

model IntakeFormField {
  id       String     @id @default(cuid())
  formId   String
  form     IntakeForm @relation(fields: [formId], references: [id])
  label    String
  type     String
  required Boolean    @default(false)
  options  String?
  position Int
  answers  FormAnswer[]
}

model FormSubmission {
  id          String          @id @default(cuid())
  formId      String?
  form        IntakeForm?     @relation(fields: [formId], references: [id])
  clientId    String
  client      Client          @relation(fields: [clientId], references: [id])
  stepId      String?
  submittedAt DateTime        @default(now())
  answers     FormAnswer[]
}

model FormAnswer {
  id           String         @id @default(cuid())
  submissionId String
  submission   FormSubmission @relation(fields: [submissionId], references: [id])
  fieldId      String?
  field        IntakeFormField? @relation(fields: [fieldId], references: [id])
  value        String
}

model Agreement {
  id          String                @id @default(cuid())
  workspaceId String
  programId   String
  program     Program               @relation(fields: [programId], references: [id])
  title       String
  content     String
  acceptances AgreementAcceptance[]
}

model AgreementAcceptance {
  id          String    @id @default(cuid())
  agreementId String?
  agreement   Agreement? @relation(fields: [agreementId], references: [id])
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  stepId      String?
  fullName    String
  acceptedAt  DateTime  @default(now())
}

model Task {
  id          String    @id @default(cuid())
  workspaceId String
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  programId   String?
  program     Program?  @relation(fields: [programId], references: [id])
  title       String
  description String?
  dueDate     DateTime?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  completedAt DateTime?
}

model Milestone {
  id          String                @id @default(cuid())
  workspaceId String
  programId   String
  program     Program               @relation(fields: [programId], references: [id])
  title       String
  description String?
  position    Int
  completions MilestoneCompletion[]
}

model MilestoneCompletion {
  id          String    @id @default(cuid())
  milestoneId String
  milestone   Milestone @relation(fields: [milestoneId], references: [id])
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  completedAt DateTime  @default(now())
}

model CheckInTemplate {
  id          String              @id @default(cuid())
  workspaceId String
  programId   String
  program     Program             @relation(fields: [programId], references: [id])
  name        String
  frequency   String
  questions   String
  createdAt   DateTime            @default(now())
  submissions CheckInSubmission[]
}

model CheckInSubmission {
  id          String          @id @default(cuid())
  templateId  String?
  template    CheckInTemplate? @relation(fields: [templateId], references: [id])
  clientId    String
  client      Client          @relation(fields: [clientId], references: [id])
  stepId      String?
  answers     String
  submittedAt DateTime        @default(now())
}

model AutomationRule {
  id              String    @id @default(cuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  triggerType     String
  conditionJson   String?
  messageTemplate String
  channel         String    @default("email")
  active          Boolean   @default(true)
}

model ActivityEvent {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  clientId     String?
  client       Client?   @relation(fields: [clientId], references: [id])
  eventType    String
  metadataJson String?
  createdAt    DateTime  @default(now())
}

model Note {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id])
  authorUserId String
  content      String
  createdAt    DateTime  @default(now())
}

model DocumentRequest {
  id          String    @id @default(cuid())
  workspaceId String
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  title       String
  description String?
  required    Boolean   @default(true)
  status      String    @default("pending")
  fileUrl     String?
  fileName    String?
  requestedAt DateTime  @default(now())
  uploadedAt  DateTime?
}

model StepCompletion {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  stepId    String
  step      ProgramStep @relation(fields: [stepId], references: [id])
  data      Json?
  completedAt DateTime @default(now())
  @@unique([clientId, stepId])
}

model AutomationLog {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  ruleType    String
  sentAt      DateTime @default(now())
}